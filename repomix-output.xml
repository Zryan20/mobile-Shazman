  /// Dispose all loaded ads
  void disposeAllAds() {
    try {
      // TODO: Dispose all ad instances
      // Example:
      // _bannerAd?.dispose();
      // _interstitialAd?.dispose();
      // _rewardedAd?.dispose();
      
