  static String hoursShort(int hours) => '${hours}h';
  static String percentComplete(int percent) => '$percent% complete';
  static String levelProgress(String level, int percent) => '$level - $percent% complete';
  
  // Get greeting based on time of day
  static String getGreeting(String name) {
    final hour = DateTime.now().hour;
    if (hour < 12) {
      return greetingMorning(name);
    } else if (hour < 17) {
      return greetingAfternoon(name);
    } else {
      return greetingEvening(name);
    }
  }
