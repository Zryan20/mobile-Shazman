  "grammarNotes": [
    {
      "title": "Numbers 1-20",
      "titleKurdish": "ژمارەکان ١-٢٠",
      "content": "English numbers are relatively easy. Note that 11-19 often end in 'teen' (like thirteen, fourteen).",
      "contentKurdish": "ژمارەکان لە ئینگلیزیدا ئاسانن. سەرنج بدە کە ١١-١٩ زۆربەی کات بە 'teen' کۆتایی دێن.",
      "examples": [
        "Ten (دە)",
        "Eleven (یازدە)",
        "Twelve (دوازدە)",
        "Thirteen (سێزدە)"
      ]
    },
    {
      "title": "Asking for Age",
      "titleKurdish": "پرسیارکردن لە تەمەن",
      "content": "The phrase 'How old are you?' is used to ask for someone's age. You answer with 'I am [number] years old'.",
      "contentKurdish": "دەستەواژەی 'How old are you?' بەکاردێت بۆ پرسیارکردن لە تەمەن. وەڵامەکەی 'I am [number] years old'ـە.",
      "examples": [
        "How old is he? (تەمەنی چەندە؟)",
        "He is twenty. (ئەو تەمەنی بیست ساڵە)"
      ]
    }
  ],
  
  "culturalNotes": [
    {
      "title": "Politeness and Age",
      "titleKurdish": "ڕێز و تەمەن",
      "content": "In some cultures, it might be impolite to ask adults their age, especially if you don't know them well. However, for children and students, it's a very common question.",
      "contentKurdish": "لە هەندێک کلتووردا، ڕەنگە بێڕێزی بێت تەمەن لە گەورەکان بپرسیت ئەگەر بە باشی نەیانناسیت. بەڵام بۆ منداڵان و قوتابیان پرسیارێکی زۆر باوە."
    }
  ],
  
  "tips": [
    "Practice counting things around you in English",
    "Remember that 'old' is used specifically for age in this context",
    "Listen to the pronunciation of 'three' (th sound)"
  ],
  
  "tipsKurdish": [
    "مەشق بکە لەسەر ژماردنی شتەکانی دەوروبەرت بە ئینگلیزی",
    "لەبیرت بێت 'old' بەکاردێت تایبەت بۆ تەمەن لەم بارەدا",
    "گوێ لە گوتنی 'three' بگرە (دەنگی th)"
  ]
}
